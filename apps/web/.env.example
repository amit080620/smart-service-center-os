# --- Supabase: your own database, created by you at supabase.com ---

# Browser-safe (NEXT_PUBLIC_ prefix means Next.js inlines these into the
# client bundle — this is intentional and safe: the anon key is protected
# by Row Level Security on the database side).
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-publishable-anon-key"

# Server-only — NEVER prefix this with NEXT_PUBLIC_, or Next.js will ship
# it to the browser. This key bypasses Row Level Security entirely.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
